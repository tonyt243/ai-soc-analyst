ANTHROPIC_API_KEY=

# claude-opus-4-8 is the default model for this project (see CLAUDE.md).
# Override to claude-sonnet-5 for cheaper/faster demo runs.
SOC_MODEL=claude-opus-4-8

# low | medium | high | xhigh | max
SOC_EFFORT=high

# Comma-separated list of origins allowed to hit the API (the Next.js dev server)
SOC_CORS_ORIGINS=http://localhost:3000

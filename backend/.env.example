ANTHROPIC_API_KEY=

# claude-opus-4-8 is the default model for this project (see CLAUDE.md).
# Override to claude-sonnet-5 for cheaper/faster demo runs.
SOC_MODEL=claude-opus-4-8

# low | medium | high | xhigh | max
SOC_EFFORT=high

# Comma-separated list of origins allowed to hit the API (the Next.js dev server)
SOC_CORS_ORIGINS=http://localhost:3000

# Both optional — enrich_ip/lookup_cve fall back to synthetic data whenever
# the corresponding key is unset (no live calls attempted), so the app and
# test suite work with zero keys configured.
# AbuseIPDB: free tier key from https://www.abuseipdb.com/account/api
SOC_ABUSEIPDB_API_KEY=
# NVD: works unauthenticated, but only at 5 req/30s (a free key raises that
# to 50 req/30s) — request one at https://nvd.nist.gov/developers/request-an-api-key
SOC_NVD_API_KEY=
